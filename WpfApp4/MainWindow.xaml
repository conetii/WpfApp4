<Window x:Class="WpfApp4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Угадай число"
        Width="800"
        Height="560"
        MinWidth="700"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#E5E7EB"
        FontFamily="Inter, Arial">
    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="StatBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="GameButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GameButtonStyle}">
            <Setter Property="Background" Value="#D1D5DB"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="#FFFFFF"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Угадай число"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#111827"/>
            <TextBlock Margin="0,6,0,0"
                       Text="{Binding PromptText}"
                       FontSize="14"
                       Foreground="#475569"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Диапазон"
                               FontSize="13"
                               Foreground="#64748B"/>
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding RangeText}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource StatBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Попыток"
                               FontSize="13"
                               Foreground="#64748B"/>
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding AttemptsText}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource StatBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Лучший результат"
                               FontSize="13"
                               Foreground="#64748B"/>
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding BestResultText}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="GuessInputBox"
                             MaxLength="3"
                             HorizontalContentAlignment="Center"
                             IsEnabled="{Binding IsInputEnabled}"
                             Text="{Binding CurrentGuess, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="GuessTextBox_PreviewTextInput"
                             DataObject.Pasting="GuessTextBox_Pasting"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Проверить"
                                Command="{Binding SubmitGuessCommand}"
                                IsDefault="True"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Grid.Column="2"
                                Content="Новая игра"
                                Command="{Binding RestartGameCommand}"
                                Style="{StaticResource GameButtonStyle}"/>
                    </Grid>

                    <Border Grid.Row="4"
                            Background="#FFFFFF"
                            BorderBrush="#D1D5DB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14">
                        <TextBlock Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding StatusBrush}"/>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Близость"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <ProgressBar Margin="0,12,0,0"
                                     Height="14"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding HeatValue, Mode=OneWay}"/>
                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding HeatMessage}"
                                   TextWrapping="Wrap"
                                   FontSize="15"
                                   Foreground="{Binding HeatBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="История"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <ListBox Margin="0,12,0,0"
                                 ItemsSource="{Binding GuessHistory}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#334155"
                                 FontSize="14"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ItemContainerStyle="{StaticResource HistoryListItemStyle}"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>

